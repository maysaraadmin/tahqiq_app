QMainWindow {
    background-color: #f5f5f5;
    font-family: "Segoe UI", "Arial";
    font-size: 12px;
}

QPushButton {
    background-color: #2c3e50;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
}

QPushButton:hover {
    background-color: #34495e;
}

QTableWidget {
    alternate-background-color: #f9f9f9;
    gridline-color: #dcdcdc;
}

QHeaderView::section {
    background-color: #ecf0f1;
    padding: 6px;
    border: 1px solid #bdc3c7;
}
